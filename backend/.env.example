# Copy this file to `.env` and fill real values. Never commit `.env`.

# --- Flask ---
FLASK_APP=app:create_app
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
# Production: set FLASK_ENV=production (or any value other than ``development``).
# Lock down open-by-default dev API access (anonymous "admin" is OFF unless set truthy):
# USIS_API_DEV_ALLOW_ANY=0
# For local UI hacking without logging in, temporarily set USIS_API_DEV_ALLOW_ANY=1 (not for production).
# Optional dev-only actor override (do not rely on this in production):
# USIS_DEV_ACTOR_USER_ID=<uuid-of-a-real-user>

# --- Browser session login (``POST /auth/login`` + ``session['user_id']``) ---
# ``GET /auth/login`` redirects to the W3CRM ``page-login.html`` on the same origin as
# ``USIS_POST_LOGIN_REDIRECT`` (or ``Referer`` when it matches ``CORS_ORIGINS``).
# Where to send the browser after a successful sign-in (Gulp static shell).
# USIS_POST_LOGIN_REDIRECT=http://127.0.0.1:3000/usis-dashboard-dark.html
# Optional ``next`` on login/logout is accepted only when its origin appears in ``CORS_ORIGINS`` (open-redirect safe).
# Use the same hostname for the static shell and ``USIS_API_BASE`` (``localhost`` vs ``127.0.0.1`` are different sites for cookies).
# Optional logo URL on the Jinja login page (defaults to GoUSIS WordPress header asset).
# USIS_PUBLIC_LOGO_URL=https://www.gousis.com/wp-content/uploads/2024/06/header-logo.png
# ``remember`` checkbox uses Flask permanent session length:
# PERMANENT_SESSION_DAYS=14

# --- Microsoft Entra ID (Azure AD) SSO — optional ---
# When all four values are set, ``GET /api/v1/auth/status`` returns ``microsoft_sso_enabled: true``
# and the W3CRM ``page-login.html`` shows “Sign in with Microsoft”.
# 1) Entra admin center → App registrations → New: Web redirect URI = MS_ENTRA_REDIRECT_URI
#    (local dev: ``http://127.0.0.1:5000/auth/microsoft/callback`` — must match exactly).
# 2) Create a client secret; grant delegated ``openid``, ``profile``, ``email``, ``offline_access`` (default scope string).
# 3) Users must already exist in ``users`` with the same email unless JIT is enabled.
# MS_ENTRA_TENANT_ID=<directory-tenant-guid-or-common>
# MS_ENTRA_CLIENT_ID=<application-client-id>
# MS_ENTRA_CLIENT_SECRET=<client-secret-value>
# MS_ENTRA_REDIRECT_URI=http://127.0.0.1:5000/auth/microsoft/callback
# Optional space-separated scopes (default below):
# MS_ENTRA_SCOPES=openid profile email offline_access
# Allow creating a local ``users`` row on first Microsoft login (off by default):
# MS_ENTRA_ALLOW_JIT_USER=0
# Restrict Microsoft sign-in to specific email domains (comma-separated, no @ prefix):
# MS_ENTRA_ALLOWED_EMAIL_DOMAINS=yourcompany.com,subsidiary.com

# --- PostgreSQL (application connection) ---
# This is what the Flask app connects with.
# Driver = psycopg (v3); host/port match your local install.
# Use 127.0.0.1 (not localhost) on Windows if auth works in pgAdmin but fails here:
# localhost often resolves to IPv6 first and pg_hba rules can differ.
DATABASE_URL=postgresql+psycopg://usis_app:CHANGE_ME_APP_PASSWORD@127.0.0.1:5432/usis_cm

# --- Browser API (W3CRM / Live Server / Gulp BrowserSync) — comma-separated origins for CORS on /api/* ---
# ``fetch(..., { credentials: 'include' })`` sends the session cookie when the page origin is listed here.
# Include every host:port you use to open HTML (BrowserSync often uses :3001–:3003). In FLASK_ENV=development
# the app also merges common localhost ports; use CORS_ORIGINS_EXTRA for LAN/Tailscale URLs.
# CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3002,http://localhost:3002

# Allow POST/PATCH/DELETE on takeoff line APIs without auth (default: on in FLASK_ENV=development only).
# TAKEOFF_API_WRITES_ENABLED=true

# --- Bootstrap-only (used by scripts\bootstrap_db.ps1 or scripts\bootstrap_db.py) ---
# Superuser login that can CREATE ROLE / CREATE DATABASE (often `postgres`).
POSTGRES_SUPERUSER_USER=postgres
# Password for that superuser (must match what works in pgAdmin for that user).
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_SUPERUSER_PASSWORD
# Optional: try `disable` if local TCP auth fails with SSL errors.
# POSTGRES_SSLMODE=disable
# Password to assign to the new `usis_app` role on first run.
# This must match the password embedded in DATABASE_URL above.
USIS_APP_DB_PASSWORD=CHANGE_ME_APP_PASSWORD
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
USIS_DB_NAME=usis_cm
USIS_APP_ROLE=usis_app

# Optional comma-separated extra browser origins (LAN / Tailscale BrowserSync), merged with CORS_ORIGINS.
# CORS_ORIGINS_EXTRA=http://100.73.198.28:3002,http://192.168.1.10:3002

# --- Leads (lead_estimates) startup (optional) ---
# If set to an existing file, Flask imports this BuildingConnected-style CSV when ``lead_estimates`` is empty
# and FLASK_ENV=development (unless AUTO_IMPORT_BC_CSV_IF_EMPTY=false).
# BC_PROJECTS_CSV=E:/path/to/bc_projects_export.csv
# AUTO_IMPORT_BC_CSV_IF_EMPTY=false
#
# If true, upsert that CSV on every Flask startup (even when the table already has rows). Use for local dev sync.
# BC_PROJECTS_CSV_MERGE_ON_STARTUP=true
# Demo rows (``usis-seed-demo-*``): upserted on every Flask startup when this is true. On in development by default.
# AUTO_SEED_DEMO_LEADS_IF_EMPTY=false
#
# ``python scripts/...`` sets USIS_BOOTSTRAP_LEADS_ON_STARTUP=0 so imports are not duplicated.

# --- BuildingConnected API (Autodesk APS 3-legged OAuth) ---
# Register an APS app, enable BuildingConnected API, set Callback URL = AUTODESK_OAUTH_REDIRECT_URI.
# Never commit real secrets; keep Client ID/Secret only in ``.env``.
# AUTODESK_CLIENT_ID=
# AUTODESK_CLIENT_SECRET=
# AUTODESK_OAUTH_REDIRECT_URI=http://127.0.0.1:5000/api/v1/integrations/buildingconnected/oauth/callback
# AUTODESK_OAUTH_SCOPES=data:read
# BUILDINGCONNECTED_API_BASE=https://developer.api.autodesk.com/construction/buildingconnected/v2
# BUILDINGCONNECTED_SYNC_ENABLED=true
# BUILDINGCONNECTED_INCLUDE_CLOSED=true
# Fernet key for encrypting OAuth refresh tokens and HR I-9 Section 1 JSON (SSN, document numbers).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, a key is derived from SECRET_KEY (fine for local dev only).
# TOKEN_ENCRYPTION_KEY=

# --- Oracle Textura Payment Management (TPM REST API) ---
# Production: https://services.texturacorp.com/ebis/api
# Test tenant: https://usint1.textura.oraclecloud.com/ebis/api
# TEXTURA_API_BASE=https://usint1.textura.oraclecloud.com/ebis/api
# TEXTURA_USERNAME=
# TEXTURA_PASSWORD=
# TEXTURA_SYNC_ENABLED=true
# TEXTURA_SYNC_PUSH_ENABLED=false
# TEXTURA_AUTO_CREATE_PROJECTS=false
# TEXTURA_POLL_INTERVAL_SEC=2
# TEXTURA_POLL_TIMEOUT_SEC=300
# Or save credentials via PUT /api/v1/integrations/textura/credentials (encrypted at rest).

# --- CSV import defaults (``scripts/db_csv_paths.py`` + loaders) ---
# Folder containing wage/material/CDTFA/Corecon/HubSpot exports (used when per-file env vars are unset).
# DATABASE_FILES_ROOT=E:/path/to/Database files
# Explicit HubSpot export path (optional; otherwise newest hubspot-crm-exports-*.csv under DATABASE_FILES_ROOT).
# HUBSPOT_CONTACTS_CSV=E:/path/to/hubspot-crm-exports-all-contacts.csv

# --- Power BI embed (reports.html) ---
# Service principal (app registration) in Azure AD: client credentials to Power BI API; add the SP as Member/Admin on the target workspace (or use capacity settings that allow embed).
# POWERBI_TENANT_ID=
# POWERBI_CLIENT_ID=
# POWERBI_CLIENT_SECRET=
# POWERBI_WORKSPACE_ID=
# POWERBI_REPORT_ID=

# --- Jinja2 print/PDF HTML (purchase order, client proposal) ---
# Shown as the seller / letterhead name on rendered documents.
# DOCUMENT_PRINT_COMPANY_NAME=USIS Construction Management

# --- Binary upload directories (optional; default under Flask ``instance/``) ---
# DRAWING_UPLOAD_FOLDER=
# SPEC_SECTION_UPLOAD_FOLDER=
# RFI_ATTACHMENT_UPLOAD_FOLDER=
# HR_I9_DOCUMENT_UPLOAD_FOLDER=
# HR_W4_DOCUMENT_UPLOAD_FOLDER=
# HR_UNION_DOCUMENT_UPLOAD_FOLDER=

# --- Backblaze B2 (S3-compatible; production on Render) ---
# When all four required vars are set, uploads use B2 instead of ``instance/``.
# See docs/backblaze-b2.md for bucket + application key setup.
# B2_APPLICATION_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET_NAME=USIS-construction-docs
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_PREFIX=prod/usis-cm

# --- Push local DB to Render (see docs/migrate-local-db-to-render.md) ---
# Set only in your PowerShell session when running scripts/push_db_to_render.ps1 — do not commit.
# LOCAL_DATABASE_URL=   (optional; defaults to DATABASE_URL above)
# RENDER_DATABASE_URL=  (required; External connection string from Render Dashboard → usis-cm-db)

# --- Transactional email (SMTP) — see docs/email.md ---
# Without MAIL_SERVER + MAIL_USERNAME + MAIL_FROM, outbound mail is dry-run (logged only).
# SendGrid example: server smtp.sendgrid.net, port 587, user apikey, password = API key.
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=
# MAIL_FROM=noreply@yourdomain.com
# Public origin for links in invite emails (Render sets RENDER_EXTERNAL_URL automatically):
# USIS_APP_PUBLIC_URL=https://your-service.onrender.com
# Send invite email when admins create users (POST /api/v1/admin/users), or pass send_invite: true per request:
# USIS_SEND_USER_INVITE_EMAIL=0
# Optional async RFI mail (requires Redis + celery worker; omit on Render for low volume):
# CELERY_BROKER_URL=redis://localhost:6379/0

# --- Render production (see docs/render-deploy.md) ---
# FLASK_ENV=production
# USIS_STATIC_ROOT=../W3CRM-v3.0-13_September_2025/gulp/dist
# DATABASE_URL=postgresql+psycopg://...  (from Render Postgres; postgres:// is auto-normalized)
# RENDER_EXTERNAL_URL=https://your-service.onrender.com
# CORS_ORIGINS=https://your-service.onrender.com
# USIS_POST_LOGIN_REDIRECT=https://your-service.onrender.com/usis-dashboard-dark.html
# USIS_ALLOW_SELF_REGISTER=1
# USIS_API_DEV_ALLOW_ANY=0
# USIS_BOOTSTRAP_LEADS_ON_STARTUP=0
# SESSION_COOKIE_SECURE=True
# SESSION_COOKIE_SAMESITE=Lax
# BOOTSTRAP_ADMIN_EMAIL=you@company.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-after-first-login
